{
  "name": "bridge",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "shared",
    "agent-windows",
    "agent-mac",
    "ui-tray"
  ],
  "scripts": {
    "build": "npm run build --workspace shared && npm run build --workspace agent-windows && npm run build --workspace agent-mac && npm run build --workspace ui-tray",
    "start:windows": "npm run start --workspace agent-windows",
    "start:windows:all": "powershell -ExecutionPolicy Bypass -File ./scripts/start-windows-all.ps1",
    "start:mac": "npm run start --workspace agent-mac",
    "start:tray": "npm run start --workspace ui-tray",
    "start:mac:all": "bash ./scripts/start-mac-all.sh",
    "setup:mac": "bash ./scripts/setup-mac.sh",
    "setup:mac:quick": "bash ./scripts/setup-mac.sh --quick",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-windows.ps1",
    "setup:windows:quick": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-windows.ps1 -Quick"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
